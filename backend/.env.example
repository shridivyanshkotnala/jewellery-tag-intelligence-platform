NODE_ENV=development
PORT=3000

# Redis — local: redis://127.0.0.1:6379  OR Redis Cloud connection string
REDIS_URL=redis://127.0.0.1:6379

# Local dev without Redis: backend uses in-memory scan store automatically in development.
# Or set explicitly:
USE_MEMORY_STORE=true

# Google Gemini API key (https://aistudio.google.com/apikey) — required for /analyze
GEMINI_API_KEY=your_gemini_api_key_here
