NODE_ENV=development
PORT=3000

# MongoDB — local install or MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/jewellery-tag

# Redis — required for registration OTP flow (local: redis://127.0.0.1:6379)
REDIS_URL=redis://127.0.0.1:6379

# Set true only for scan demo without Redis (auth/register still needs Redis)
# USE_MEMORY_STORE=true

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=change-me-to-a-long-random-access-secret
JWT_REFRESH_SECRET=change-me-to-a-long-random-refresh-secret

# Google Gemini API key (https://aistudio.google.com/apikey) — required for /analyze
GEMINI_API_KEY=your_gemini_api_key_here

# Phone OTP (MSG91) — dev placeholders work for startup; OTP logs in terminal
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id

# Email OTP (Resend) — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
